{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["@playwright/test"],
    "outDir": "dist"
  },
  "include": [
    "e2e/**/*.ts",
    "playwright.config.ts"
  ]
}
